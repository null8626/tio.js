{
  "include": ["src/**/*.ts"],
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "noImplicitAny": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "allowUnreachableCode": false,
    "noUnusedParameters": true,
    "strict": true,
    "module": "nodenext",
    "target": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "nodenext",
    "sourceMap": true,
    "types": ["node"]
  }
}
